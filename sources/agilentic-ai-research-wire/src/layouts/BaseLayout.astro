---
import '../styles/global.css';
const { title = 'AI Research Wire', description = 'A public research notebook for AI systems, agents, evaluation, and product strategy.' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://agilentic.github.io');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header">
      <div class="shell nav-shell">
        <a class="brand" href={import.meta.env.BASE_URL} aria-label="AI Research Wire home">
          <span class="brand-mark">A</span>
          <span><strong>AI Research Wire</strong><small>Public research notebook</small></span>
        </a>
        <nav aria-label="Primary navigation">
          <a href={`${import.meta.env.BASE_URL}archive/`}>Archive</a>
          <a href={`${import.meta.env.BASE_URL}tags/`}>Tags</a>
          <a href={`${import.meta.env.BASE_URL}notes/`}>Notes</a>
          <a href="https://github.com/agilentic/ai-research-wire">GitHub</a>
        </nav>
      </div>
    </header>
    <main id="content"><slot /></main>
    <footer class="site-footer">
      <div class="shell footer-grid">
        <p><strong>AI Research Wire</strong> is a static, Markdown-first publication. GitHub is the source of truth.</p>
        <p><a href="https://github.com/agilentic/ai-research-wire/tree/main/research/posts">Write in Markdown</a> · <a href={`${import.meta.env.BASE_URL}rss.xml`}>RSS</a></p>
      </div>
    </footer>
  </body>
</html>
