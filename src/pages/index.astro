---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getArticles, allTags } from '../lib/articles';
const articles = await getArticles();
const featured = articles.find((article) => article.data.featured) ?? articles[0];
const latest = articles.filter((article) => article.id !== featured?.id).slice(0, 6);
const tags = allTags(articles).slice(0, 18);
---
<BaseLayout>
  <section class="hero shell">
    <div class="hero-copy">
      <p class="eyebrow">Agilentic public research wire</p>
      <h1>Field notes and long-form essays on AI agents, evaluation, and research systems.</h1>
      <p class="lead">A static, searchable publication inspired by Gwern-style durable notes and TuringWire-style clarity. Every article starts as Markdown in GitHub.</p>
      <div class="hero-actions"><a class="button" href={`${import.meta.env.BASE_URL}archive/`}>Browse the archive</a><a class="button ghost" href="https://github.com/agilentic/ai-research-wire/tree/main/research/posts">Read the source</a></div>
    </div>
    {featured && <div class="featured-panel"><span class="eyebrow">Featured research</span><ArticleCard article={featured} /></div>}
  </section>
  <section class="shell search-panel" aria-labelledby="search-title">
    <div><p class="eyebrow">Searchable archive</p><h2 id="search-title">Find research by title, abstract, tag, or category.</h2></div>
    <label class="search-box"><span class="sr-only">Search articles</span><input id="site-search" type="search" placeholder="Search agents, evals, benchmarks…" autocomplete="off" /></label>
    <div id="search-results" class="search-results" aria-live="polite"></div>
  </section>
  <section class="shell two-column">
    <div><div class="section-heading"><p class="eyebrow">Latest</p><h2>Recent research</h2></div><div class="card-grid">{latest.map((article) => <ArticleCard article={article} compact />)}</div></div>
    <aside class="sidebar-block"><h2>Research map</h2><p>Use tags as entry points into active themes and evergreen notes.</p><div class="tag-cloud">{tags.map((tag) => <a class="tag" href={`${import.meta.env.BASE_URL}tags/${encodeURIComponent(tag)}/`}>{tag}</a>)}</div></aside>
  </section>
  <script src={`${import.meta.env.BASE_URL}search.js`} defer></script>
</BaseLayout>
